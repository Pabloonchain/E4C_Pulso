{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/passport",
      "dest": "api/passport.ts"
    },
    {
      "src": "/api/disbursement",
      "dest": "api/disbursement.ts"
    },
    {
      "src": "/api/challenge",
      "dest": "api/challenge.ts"
    },
    {
      "src": "/api/reputation",
      "dest": "api/reputation.ts"
    },
    {
      "src": "/api/claim",
      "dest": "api/claim.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(index.html)?",
      "dest": "/index.html"
    }
  ]
}

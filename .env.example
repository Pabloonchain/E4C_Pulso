# -----------------------------------------------------------------------------
# E4C Stellar Disbursement & Integration Service - Environment Template
# Copy this file to '.env' and fill in your actual credentials.
# DO NOT COMMIT THE '.env' FILE TO GITHUB.
# -----------------------------------------------------------------------------

# --- Privy Configuration ---
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# --- Stellar / Soroban Network Configuration ---
# Stellar Testnet Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed Soroban Escrow Contract Address (CD5L45...)
ESCROW_CONTRACT_ID=CD5L453U2XWNG2K2ND5L4W7LWD6Z5N2WCD5L4W7LWD6Z5N2WCD5L4W7L

# Stellar testnet USDC contract ID (the token address to transfer)
USDC_TOKEN_CONTRACT_ID=CCW6ZG0FGDZDUZZD5AVKVGW4EDKVSTK7JD4RBEJGQCBBJD6GDXP3TLHE

# --- Admin Wallet Keys (Signs transactions for claiming rewards) ---
# This is the secret key of the administrator/escrow manager (S...)
ADMIN_SECRET_KEY=SBCXP...
